{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ritsu-ctx-event",
  "title": "Ritsu Context Event",
  "description": "v5.2.0 — Ritsu ctx JSONL 事件 Schema。自适应分级交付流。",
  "type": "object",
  "required": ["ts", "correlation_id", "skill", "domain", "status"],
  "properties": {
    "ts": {
      "type": "string",
      "pattern": "^\\d{8}-\\d{6}$"
    },
    "correlation_id": {
      "type": "string",
      "pattern": "^cid-\\d{8}-\\d+$"
    },
    "skill": {
      "type": "string",
      "enum": ["init", "think", "dev", "hunt", "review"]
    },
    "domain": {
      "type": "string",
      "enum": ["frontend", "backend", "fullstack", "infra", "data"]
    },
    "tier": {
      "type": "string",
      "enum": ["micro", "standard", "critical"]
    },
    "status": {
      "type": "string",
      "enum": ["started", "done", "failed", "artifact_written"]
    },
    "step": {
      "type": "string",
      "pattern": "^\\d+/\\d+$"
    },
    "artifact": {
      "type": "string"
    },
    "error": {
      "type": "string"
    },
    "artifact_meta": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["design-sheet", "design-brief", "dev-report", "assurance-sheet", "diagnosis", "ctx"]
        },
        "size_bytes": {
          "type": "integer"
        },
        "summary": {
          "type": "string"
        }
      },
      "required": ["type", "size_bytes", "summary"]
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "started" } } },
      "then": { "required": ["step"] }
    },
    {
      "if": { "properties": { "status": { "const": "artifact_written" } } },
      "then": { "required": ["artifact", "artifact_meta"] }
    },
    {
      "if": { "properties": { "status": { "const": "done" } } },
      "then": { "required": ["step"] }
    },
    {
      "if": { "properties": { "status": { "const": "failed" } } },
      "then": { "required": ["error"] }
    }
  ]
}

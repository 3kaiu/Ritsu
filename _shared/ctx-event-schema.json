{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ritsu-ctx-event",
  "title": "Ritsu Context Event",
  "description": "v5.2.0 — Ritsu ctx JSONL 事件 Schema。自适应分级交付流。注意：freestyle 不在此列，不写入 ctx。",
  "type": "object",
  "required": ["ts", "status"],
  "properties": {
    "ts": {
      "type": "string",
      "pattern": "^\\d{8}-\\d{6}$"
    },
    "correlation_id": {
      "type": "string",
      "deprecated": true,
      "description": "Legacy field, replaced by trace_id + span_id in v6.0+"
    },
    "trace_id": {
      "type": "string",
      "pattern": "^trace-\\d{8}-[0-9a-f]{16}$"
    },
    "span_id": {
      "type": "string",
      "pattern": "^span-[0-9a-f]{8}$"
    },
    "parent_span_id": {
      "type": "string",
      "pattern": "^span-[0-9a-f]{8}$"
    },
    "agent": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "role": { "type": "string" },
        "session_id": { "type": "string" }
      }
    },
    "span_kind": {
      "type": "string",
      "enum": ["root", "internal", "client", "server"]
    },
    "skill": {
      "type": "string",
      "enum": ["init", "think", "dev", "hunt", "review"]
    },
    "domain": {
      "type": "string",
      "enum": ["frontend", "backend", "fullstack", "infra", "data"]
    },
    "tier": {
      "type": "string",
      "enum": ["micro", "standard", "critical"]
    },
    "status": {
      "type": "string",
      "enum": ["started", "done", "failed", "artifact_written", "violation_detected"]
    },
    "step": {
      "type": "string",
      "pattern": "^\\d+/\\d+$"
    },
    "artifact": {
      "type": "string"
    },
    "error": {
      "type": "string"
    },
    "cost": {
      "type": "object",
      "properties": {
        "tokens_in": { "type": "integer", "minimum": 0 },
        "tokens_out": { "type": "integer", "minimum": 0 },
        "model": { "type": "string" },
        "duration_ms": { "type": "integer", "minimum": 0 }
      }
    },
    "violation": {
      "type": "object",
      "properties": {
        "rule_id": { "type": "string", "pattern": "^(POL|AP|R)-\\d+$" },
        "severity": { "enum": ["fatal", "error", "warn", "hard_stop"] },
        "evidence": { "type": "string" },
        "blocked": { "type": "boolean" }
      },
      "required": ["rule_id", "severity"]
    },
    "artifact_meta": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["design-sheet", "design-brief", "dev-report", "assurance-sheet", "diagnosis", "ctx"]
        },
        "size_bytes": {
          "type": "integer"
        },
        "summary": {
          "type": "string"
        }
      },
      "required": ["type", "size_bytes", "summary"]
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "started" } } },
      "then": { "required": ["step"] }
    },
    {
      "if": { "properties": { "status": { "const": "artifact_written" } } },
      "then": { "required": ["artifact", "artifact_meta"] }
    },
    {
      "if": { "properties": { "status": { "const": "done" } } },
      "then": { "required": ["step"] }
    },
    {
      "if": { "properties": { "status": { "const": "failed" } } },
      "then": { "required": ["error"] }
    }
  ]
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ritsu-ctx-event",
  "title": "Ritsu Context Event",
  "description": "v3.8.0 — Ritsu ctx JSONL 事件 Schema（精简版）。每行一条记录，追加不覆盖。仅保留有实际消费者的 4 种核心事件类型。",
  "type": "object",
  "required": ["ts", "correlation_id", "skill", "domain", "status"],
  "properties": {
    "ts": {
      "type": "string",
      "pattern": "^\\d{8}-\\d{6}$",
      "description": "YYYYMMDD-HHMMSS 格式时间戳"
    },
    "correlation_id": {
      "type": "string",
      "pattern": "^cid-\\d{8}-\\d+$",
      "description": "任务链路关联 ID，由 ritsu_emit_event 自动生成，同链路自动继承"
    },
    "skill": {
      "type": "string",
      "enum": [
        "route",
        "pipe",
        "init",
        "think",
        "dev",
        "optimize",
        "review",
        "hunt",
        "triage",
        "test",
        "deploy",
        "document",
        "read",
        "refactor"
      ],
      "description": "技能名"
    },
    "domain": {
      "type": "string",
      "enum": ["frontend", "backend", "fullstack", "infra", "data"],
      "description": "领域值"
    },
    "status": {
      "type": "string",
      "enum": ["started", "done", "failed", "artifact_written"],
      "description": "事件类型（精简为 4 种核心类型：started=会话恢复, done/failed=状态判定, artifact_written=产物追踪）"
    },
    "step": {
      "type": "string",
      "pattern": "^\\d+/\\d+$",
      "description": "格式 {current}/{total}，如 2/5"
    },
    "artifact": {
      "type": "string",
      "description": "产物文件路径（artifact_written 时必填）"
    },
    "error": {
      "type": "string",
      "description": "failed 时必填，一句话错误描述"
    },
    "artifact_meta": {
      "type": "object",
      "description": "artifact_written 时必填",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "intake-ticket",
            "delivery-report",
            "assurance-report",
            "handoff",
            "diagnosis",
            "review-stamp",
            "optimize-report",
            "ctx"
          ],
          "description": "产物类型"
        },
        "size_bytes": {
          "type": "integer",
          "description": "文件大小"
        },
        "summary": {
          "type": "string",
          "description": "一句话摘要"
        }
      },
      "required": ["type", "size_bytes", "summary"]
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "started" } } },
      "then": { "required": ["step"] }
    },
    {
      "if": { "properties": { "status": { "const": "artifact_written" } } },
      "then": { "required": ["step", "artifact", "artifact_meta"] }
    },
    {
      "if": { "properties": { "status": { "const": "done" } } },
      "then": { "required": ["step"] }
    },
    {
      "if": { "properties": { "status": { "const": "failed" } } },
      "then": { "required": ["error"] }
    }
  ]
}

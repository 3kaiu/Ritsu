{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ritsu-ctx-event",
  "title": "Ritsu Context Event",
  "description": "v4.1.0 — Ritsu ctx JSONL 事件 Schema。显式阶段交付流，去中心化产物追踪。",
  "type": "object",
  "required": ["ts", "correlation_id", "skill", "domain", "status"],
  "properties": {
    "ts": {
      "type": "string",
      "pattern": "^\\d{8}-\\d{6}$",
      "description": "YYYYMMDD-HHMMSS 格式时间戳"
    },
    "correlation_id": {
      "type": "string",
      "pattern": "^cid-\\d{8}-\\d+$",
      "description": "任务链路关联 ID"
    },
    "skill": {
      "type": "string",
      "enum": [
        "init",
        "think",
        "dev",
        "test",
        "hunt",
        "review",
        "deploy",
        "triage",
        "read",
        "optimize",
        "refactor",
        "document"
      ]
    },
    "domain": {
      "type": "string",
      "enum": ["frontend", "backend", "fullstack", "infra", "data"]
    },
    "status": {
      "type": "string",
      "enum": ["started", "done", "failed", "artifact_written"]
    },
    "step": {
      "type": "string",
      "pattern": "^\\d+/\\d+$"
    },
    "artifact": {
      "type": "string"
    },
    "error": {
      "type": "string"
    },
    "artifact_meta": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "design-sheet",
            "dev-report",
            "assurance-sheet",
            "handoff",
            "diagnosis",
            "optimize-report",
            "ctx"
          ]
        },
        "layer": {
          "type": "string",
          "enum": ["primary", "evidence", "system"]
        },
        "size_bytes": {
          "type": "integer"
        },
        "summary": {
          "type": "string"
        }
      },
      "required": ["type", "size_bytes", "summary"]
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "started" } } },
      "then": { "required": ["step"] }
    },
    {
      "if": { "properties": { "status": { "const": "artifact_written" } } },
      "then": { "required": ["artifact", "artifact_meta"] }
    },
    {
      "if": { "properties": { "status": { "const": "done" } } },
      "then": { "required": ["step"] }
    },
    {
      "if": { "properties": { "status": { "const": "failed" } } },
      "then": { "required": ["error"] }
    }
  ]
}

# Ritsu MCP Tool Schema 声明 v6.5.0

tools:
  - name: ritsu_emit_event
    description: 向当月 ctx 文件追加一条结构化事件记录。仅 Critical (P2) 级别强制。
    call_template:
      tool: ritsu_emit_event
      params:
        event_type: "{started|done|failed|artifact_written|violation_detected}"
        step: "{N}/{M}"
        skill: "{skill_name}"
        domain: "{value}"
    input:
      event_type:
        type: enum
        values: [started, done, failed, artifact_written, violation_detected]
        required: true
      step:
        type: string
        required: false
      correlation_id:
        type: string
        required: false
      trace_id:
        type: string
        required: false
      span_id:
        type: string
        required: false
      agent:
        type: object
        required: false
      skill:
        type: string
        required: false
      domain:
        type: string
        required: false
      artifact:
        type: string
        required: false
      error:
        type: string
        required: false
      artifact_meta:
        type: object
        required: false
      violation:
        type: object
        required: false
    output_schema:
      type: object
      required: [written, line_count]
      properties:
        written: { type: boolean }
        line_count: { type: integer }

  - name: ritsu_read_ctx
    description: 读取当月 ctx 文件的状态摘要。返回 last_incomplete、last_completed 等。
    call_template:
      tool: ritsu_read_ctx
      params: {}
    input:
      detail:
        type: boolean
        required: false
        description: "If true, returns full event history and detailed failure analysis. Default is false (compact mode)."
    output_schema:
      type: object
      required: [last_incomplete, last_completed, recent_entries, recovery_context]
      properties:
        last_incomplete: { type: object }
        last_completed: { type: object }
        recent_entries: { type: array }
        recovery_context: { type: object }

  - name: ritsu_read_agents
    description: 读取并解析 AGENTS.md，返回 domain、version 等，并执行环境感知。
    call_template:
      tool: ritsu_read_agents
      params: {}
    input: {}
    output_schema:
      type: object
      required: [path, domain]
      properties:
        path: { type: string }
        ritsu_version: { type: string }
        domain: { type: string }
        tech_fingerprints: { type: array }

  - name: ritsu_write_artifact
    description: 写入产物文件到 .ritsu/ 目录。支持 design-sheet/design-brief/dev-report/assurance-sheet/diagnosis。
    call_template:
      tool: ritsu_write_artifact
      params:
        type: "{type}"
        filename: "{filename}"
        content: "{content}"
    input:
      type:
        type: enum
        values: [design-sheet, design-brief, dev-report, assurance-sheet, diagnosis, coordination-sheet]
        required: true
      filename: { type: string, required: true }
      content: { type: string, required: true }
      artifact_meta: { type: object, required: false }
    output_schema:
      type: object
      required: [path, size_bytes]
      properties:
        path: { type: string }
        size_bytes: { type: integer }

  - name: ritsu_list_artifacts
    description: 列出 .ritsu/ 目录下的产物文件。
    call_template:
      tool: ritsu_list_artifacts
      params:
        type: "all"
    input:
      type: { type: string, required: false }
    output_schema:
      type: object
      required: [files, total_count]
      properties:
        files: { type: array }
        total_count: { type: integer }

  - name: ritsu_exec
    description: 在项目根目录执行单命令（内置安全边界）。
    call_template:
      tool: ritsu_exec
      params:
        command: "{命令}"
    input:
      command: { type: string, required: true }
      max_output_lines: { type: integer, required: false }
      timeout_ms: { type: integer, required: false }
    output_schema:
      type: object
      required: [ok, output]
      properties:
        ok: { type: boolean }
        output: { type: string }

  - name: ritsu_inspect_git_changes
    description: "统一 Git 变更与 diff 检视：支持 status (变更列表)、stat (diffstat)、chunks (hunks 摘要)、full (完整 diff)。"
    call_template:
      tool: ritsu_inspect_git_changes
      params:
        mode: full
        staged: true
        unstaged: true
    input:
      mode:
        type: enum
        values: [status, stat, chunks, full]
        required: false
      cached: { type: boolean, required: false }
      max_output_lines: { type: integer, required: false }
      top_n: { type: integer, required: false }
      staged: { type: boolean, required: false }
      unstaged: { type: boolean, required: false }
    output_schema:
      type: object


  - name: ritsu_run_quality_gates
    description: 执行项目质量门禁（Lint + Test）。
    call_template:
      tool: ritsu_run_quality_gates
      params:
        skip_lint: false
        skip_test: false
        trace_id: "{trace_id}"
        span_id: "{span_id}"
    input:
      skip_lint: { type: boolean, required: false }
      skip_test: { type: boolean, required: false }
      skip_policy: { type: boolean, required: false }
      timeout_ms: { type: integer, required: false }
      correlation_id: { type: string, required: false }
      trace_id: { type: string, required: false }
      span_id: { type: string, required: false }
      parent_span_id: { type: string, required: false }
      skill: { type: string, required: false }
      domain: { type: string, required: false }
    output_schema:
      type: object
      required: [passed, lint, test]
      properties:
        passed: { type: boolean }
        lint: { type: object }
        test: { type: object }

  - name: ritsu_read_preferences
    description: 读取项目级用户偏好（从历史 review 中学习到的规则）。
    call_template:
      tool: ritsu_read_preferences
    input: {}
    output_schema:
      type: object
      properties:
        rules: { type: array }

  - name: ritsu_write_preference
    description: 写入或更新项目级用户偏好。
    call_template:
      tool: ritsu_write_preference
      params:
        rule:
          match_regex: "{regex}"
          scope: "{scope}"
    input:
      rule:
        type: object
        properties:
          match_regex: { type: string }
          forbid_lib: { type: string }
          require_call: { type: string }
          pattern: { type: string }
          scope:
            type: enum
            values: [coding_style, library_choice, naming_convention, architecture]
            required: true
          source: { type: string }
          auto_inject_to: { type: array }
          confidence: { type: number }
    output_schema:
      type: object
      properties:
        ok: { type: boolean }
        id: { type: string }
        matches: { type: array }

  - name: ritsu_span_lifecycle
    description: "生命周期Span管理：支持 open (新建/创建) 与 close (完成/失败关闭)。"
    call_template:
      tool: ritsu_span_lifecycle
      params:
        action: open
        skill: "{skill_name}"
        domain: "{value}"
    input:
      action:
        type: enum
        values: [open, close]
        required: true
      skill: { type: string, required: false }
      domain: { type: string, required: false }
      trace_id: { type: string, required: false }
      span_id: { type: string, required: false }
      parent_span_id: { type: string, required: false }
      status:
        type: enum
        values: [done, failed]
        required: false
      error: { type: string, required: false }
      cost: { type: object, required: false }
      step: { type: string, required: false }
      metadata: { type: object, required: false }
      agent: { type: object, required: false }
      name: { type: string, required: false }
    output_schema:
      type: object


  - name: ritsu_join_trace
    description: 查询 trace 状态，返回 span tree 与 artifacts 列表。
    call_template:
      tool: ritsu_join_trace
      params:
        trace_id: "{trace_id}"
    input:
      trace_id: { type: string, required: true }
    output_schema:
      type: object
      required: [trace_id, tree, artifacts]
      properties:
        trace_id: { type: string }
        tree: { type: array }
  
  - name: ritsu_init_trust_key
    description: "初始化项目级 HMAC 信任密钥（存储在 .ritsu/secret.key），开启 Trace 签名机制。"
    call_template:
      tool: ritsu_init_trust_key
      params: {}
    input:
      force: { type: boolean, required: false, description: "If true, overwrites existing key." }
    output_schema:
      type: object
      required: [ok, path]
      properties:
        ok: { type: boolean }
        path: { type: string }

  - name: ritsu_file_lease
    description: "防冲突文件锁定机制：支持 claim (申请锁定)、release (释放锁定) 与 list (查看当前活跃锁定)。"
    call_template:
      tool: ritsu_file_lease
      params:
        action: claim
        path: "{file_path}"
        span_id: "{span_id}"
    input:
      action:
        type: enum
        values: [claim, release, list]
        required: true
      path: { type: string, required: false }
      span_id: { type: string, required: false }
      ttl_ms: { type: integer, required: false }
    output_schema:
      type: object

  - name: ritsu_task_coordination
    description: "多Agent子任务协同：支持 claim (领取任务) 与 list (获取待领取列表)。"
    call_template:
      tool: ritsu_task_coordination
      params:
        action: claim
        span_id: "{span_id}"
        agent_id: "{agent_id}"
    input:
      action:
        type: enum
        values: [claim, list]
        required: true
      span_id: { type: string, required: false }
      agent_id: { type: string, required: false }
    output_schema:
      type: object


  - name: ritsu_verify_trace
    description: "校验 Trace 链路中所有事件的 HMAC 签名，确保数据完整性与来源可信。"
    call_template:
      tool: ritsu_verify_trace
      params:
        trace_id: "{trace_id}"
    input:
      trace_id: { type: string, required: true }
    output_schema:
      type: object
      required: [trace_id, valid, violation_count]
      properties:
        trace_id: { type: string }
        valid: { type: boolean }
        violation_count: { type: integer }
        details: { type: array }
  
  - name: ritsu_bootstrap_ecosystem
    description: "静默写入项目根 .mcp.json（Claude Code 标准）与 .ritsu/ecosystem.json；Cursor 为 opt-in。"
    call_template:
      tool: ritsu_bootstrap_ecosystem
      params:
        host: claude-code
    input:
      host:
        type: enum
        values: [claude-code, cursor, all]
        required: false
      include_cursor_hooks: { type: boolean, required: false }
    output_schema:
      type: object
      required: [project_root, files_written, ecosystem]
      properties:
        project_root: { type: string }
        files_written: { type: array }
        files_merged: { type: array }
        ecosystem: { type: object }
        notes: { type: array }

  - name: ritsu_preflight
    description: "按阶段一键串联 read_ctx、changed_files、policy、inspect_diff、OpenSpec 等，返回 context_pack。"
    call_template:
      tool: ritsu_preflight
      params:
        stage: "{think|dev|hunt|review}"
        tier: "{P0|P1|P2}"
        task_summary: "{summary}"
    input:
      stage:
        type: enum
        values: [think, dev, hunt, review]
        required: true
      tier:
        type: string
        required: false
      task_summary:
        type: string
        required: false
    output_schema:
      type: object
      required: [ok, context_pack]
      properties:
        ok: { type: boolean }
        context_pack: { type: object }

  - name: ritsu_sync_openspec_contracts
    description: "从 OpenSpec change proposal 提取需求并写入精简 design-sheet（contracts 表）。"
    call_template:
      tool: ritsu_sync_openspec_contracts
      params:
        change_id: "{change_id}"
    input:
      change_id:
        type: string
        required: false
        description: "openspec/changes/<id>；省略则取最近修改的 change"
    output_schema:
      type: object
      required: [change_id, contracts, design_sheet_path]
      properties:
        change_id: { type: string }
        contracts: { type: array }
        design_sheet_path: { type: string }
        openspec_proposal_path: { type: string }

  - name: ritsu_patch_artifact
    description: "通过给定的块进行增量替换，更新大型 Markdown 文件的内容，实现 Zero-Token 开销。"
    call_template:
      tool: ritsu_patch_artifact
      params:
        filename: "{filename}"
        target_content: "{old}"
        replacement_content: "{new}"
    input:
      filename: { type: string, required: true }
      target_content: { type: string, required: true }
      replacement_content: { type: string, required: true }
    output_schema:
      type: object
      required: [path, size_bytes]
      properties:
        path: { type: string }
        size_bytes: { type: integer }

{
  "name": "ritsu-mcp-server",
  "version": "7.0.0",
  "ritsu_protocol_version": "7.0.0",
  "description": "Ritsu — AI Delivery Workflow Skill Engine. MCP server with policy, quality gates, and cross-session memory.",
  "packageManager": "bun@1.3.5",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ritsu-mcp-server": "dist/index.js",
    "ritsu": "dist/cli.js"
  },
  "files": [
    "dist",
    "package.json",
    "bun.lock",
    "native/ritsu-native.*.node"
  ],
  "scripts": {
    "build": "tsc && bun run scripts/copy-resources.js",
    "build:native": "cd native && cargo build --release && cp target/release/libritsu_native.dylib ritsu-native.darwin-arm64.node 2>/dev/null; cp target/release/librithsu_native.so ritsu-native.linux-x64.node 2>/dev/null; true",
    "dev": "bun --watch src/index.ts",
    "start": "bun dist/index.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix && prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/3kaiu/Ritsu.git"
  },
  "bugs": {
    "url": "https://github.com/3kaiu/Ritsu/issues"
  },
  "homepage": "https://github.com/3kaiu/Ritsu#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "ajv": "8.x",
    "fast-glob": "^3.3.3",
    "js-yaml": "^4.1.0",
    "typescript": "^5.8.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.2",
    "@types/bun": "^1.3.14",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.5.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "license": "MIT",
  "keywords": ["ai", "mcp", "claude-code", "workflow", "policy", "quality-gates"]
}

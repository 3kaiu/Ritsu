{
  "name": "ritsu-mcp-server",
  "version": "3.5.1",
  "description": "Ritsu MCP Server SDK — 结构化 I/O 原语，供 AI 技能调用",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ritsu-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "build:wasm": "cd core && wasm-pack build --target nodejs --release --out-dir ../pkg",
    "postinstall": "node scripts/download-wasm.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "ajv": "^8.17.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
